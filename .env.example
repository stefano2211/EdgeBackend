# ── Core ──────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=DEBUG

# ── Database (PostgreSQL) ─────────────────────────────────────────
POSTGRES_USER=edge
POSTGRES_PASSWORD=edge
POSTGRES_DB=edgebackend
DATABASE_URL=postgresql+asyncpg://edge:edge@postgres:5432/edgebackend

# ── Qdrant (Vector DB) ────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# ── vLLM (LLM Inference) ────────────────────────────────────────
VLLM_ENABLED=True
VLLM_BASE_URL=http://vllm:8000/v1
VLLM_API_KEY=
VLLM_MODEL_NAME=Qwen/Qwen3.5-9B-Instruct
VLLM_MAX_TOKENS=8192

# ── Ollama (Alternative LLM Inference) ────────────────────────────
OLLAMA_ENABLED=True
OLLAMA_BASE_URL=http://ollama:11434/v1
OLLAMA_MODEL=qwen3.5:9b
OLLAMA_MAX_TOKENS=8192

# ── Default LLM Provider ─────────────────────────────────────────
# "auto" = detect which backend is running (vLLM preferred if both)
# "vllm" | "ollama" = force a specific provider
DEFAULT_LLM_PROVIDER=auto

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Security ───────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-secret-key-min-32-chars-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── File Upload ─────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=104857600

# ── Embeddings ──────────────────────────────────────────────────────
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2
