# EdgeBackend environment variables
# Copy this file to .env and fill in the values.

# ── Core ──
APP_ENV=development
LOG_LEVEL=DEBUG

# ── Database ──
DATABASE_URL=postgresql+asyncpg://edge:edge@localhost:5432/edgebackend
DATABASE_POOL_SIZE=20

# ── Qdrant ──
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── vLLM (GPU) ──
VLLM_ENABLED=False
VLLM_BASE_URL=http://vllm:8000/v1
VLLM_API_KEY=
VLLM_MODEL=Qwen/Qwen3.5-9B-Instruct
VLLM_MAX_TOKENS=8192

# ── Ollama (CPU/GPU fallback) ──
OLLAMA_ENABLED=True
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3.5:9b
OLLAMA_MAX_TOKENS=8192
OLLAMA_NUM_CTX=32000

# ── LLM Provider Selection ──
# auto | vllm | ollama
DEFAULT_LLM_PROVIDER=ollama

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── Security ──
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
EVENT_INGEST_API_KEY=change-me-event-ingest-key

# ── OAuth (Gmail integration) ──
OAUTH_REDIRECT_URL=http://localhost:8000/api/v1/integrations/oauth/callback
GMAIL_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-google-client-secret

# ── Credential Encryption ──
CREDENTIAL_ENCRYPTION_KEY=
CREDENTIAL_ENCRYPTION_KEY_PREVIOUS=

# ── Frontend ──
FRONTEND_ORIGIN=http://localhost:5173

# ── CORS ──
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── MinIO / S3 ──
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents
MINIO_SECURE=False
MINIO_REGION=us-east-1

# ── Upload limits ──
MAX_UPLOAD_SIZE=104857600

# ── Embeddings ──
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2
SPARSE_EMBEDDINGS_MODEL=Qdrant/bm25

# ── RAG Pipeline ──
HYBRID_SEARCH_ENABLED=True
RAG_PREFETCH_LIMIT=50
RAG_RERANK_TOP_K=5
RAG_MIN_RELEVANCE_SCORE=0.35

# ── Reranker ──
RERANKER_ENABLED=True
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ── Contextual Chunking ──
CONTEXTUAL_CHUNKING_ENABLED=True

# ── Query Enhancement ──
QUERY_ENHANCEMENT_ENABLED=True

# ── Reactive Pipeline ──
REACTIVE_NOTIFICATION_EMAIL=stefano.andres2004@gmail.com
